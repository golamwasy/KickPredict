generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String               @id @default(uuid())
  fullName         String               @unique
  email            String               @unique
  username         String               @unique
  passwordHash     String
  isActive         Boolean              @default(false)
  role             Role                 @default(USER)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  hasAcceptedTerms Boolean              @default(false)
  bets             Bet[]
  passwordTokens   PasswordResetToken[]
  wallet           Wallet?
}

model PendingRegistration {
  id           String   @id @default(uuid())
  fullName     String
  email        String   @unique
  username     String   @unique
  passwordHash String
  code         String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Team {
  id           String  @id @default(uuid())
  name         String  @unique
  code         String  @unique
  flagUrl      String?
  team1Matches Match[] @relation("Team1")
  team2Matches Match[] @relation("Team2")
}

model Match {
  id                 String      @id @default(uuid())
  team1Id            String
  team2Id            String
  kickoffTime        DateTime
  status             MatchStatus @default(UPCOMING)
  team1Goals         Int?
  team2Goals         Int?
  apiFixtureId       Int?        @unique
  firstTeamToScoreId String?
  bets               Bet[]
  team1              Team        @relation("Team1", fields: [team1Id], references: [id])
  team2              Team        @relation("Team2", fields: [team2Id], references: [id])
}

model Wallet {
  id           String        @id @default(uuid())
  userId       String        @unique
  balance      Int           @default(10000)
  loan         Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id           String          @id @default(uuid())
  walletId     String
  type         TransactionType
  amount       Int
  balanceAfter Int
  betId        String?
  note         String?
  createdAt    DateTime        @default(now())
  bet          Bet?            @relation(fields: [betId], references: [id])
  wallet       Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model Bet {
  id              String        @id @default(uuid())
  userId          String
  matchId         String
  betType         BetType
  stake           Int
  multiplier      Float
  potentialPayout Int
  predictedData   Json
  status          BetStatus     @default(PENDING)
  settledAt       DateTime?
  createdAt       DateTime      @default(now())
  match           Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions    Transaction[]

  @@unique([userId, matchId, betType])
}

model ApiSyncLog {
  id        String   @id @default(uuid())
  endpoint  String
  status    String
  message   String?
  createdAt DateTime @default(now())
}

enum Role {
  USER
  ADMIN
}

enum MatchStatus {
  UPCOMING
  OPEN
  LOCKED
  LIVE
  FINISHED
  CANCELLED
}

enum TransactionType {
  SIGNUP_BONUS
  BET_PLACED
  BET_WON
  BET_LOST
  BET_REFUNDED
  ADMIN_ADJUST
  LOAN_REPAYMENT
  LOAN_GRANTED
}

enum BetType {
  MATCH_WINNER
  EXACT_SCORE
  OVER_UNDER_GOALS
  BOTH_TEAMS_TO_SCORE
  CORRECT_MARGIN
  FIRST_TO_SCORE
  DOUBLE_CHANCE
}

enum BetStatus {
  PENDING
  WON
  LOST
  VOID
}
